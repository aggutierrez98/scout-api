generator client {
  provider = "prisma-client-js"
  version = "7.0.0"
  previewFeatures = ["driverAdapters"]
  engineType      = "client" 
}

datasource db {
  provider = "sqlite"
}

enum Progresion {
  INTERRAMA
  LOBO_PATA_TIERNA
  LOBO_SALTADOR
  LOBO_RASTREADOR
  LOBO_CAZADOR
  PISTAS
  SENDA
  RUMBO
  TRAVESIA
  FUEGO
  TIERRA
  AGUA
  AIRE
  ENCUENTRO
  COMPROMISO
  PROYECCION
}

enum Rama {
  CASTORES
  MANADA
  SCOUTS
  CAMINANTES
  ROVERS
}

model User {
  id             Int            @id @default(autoincrement())
  uuid           String         @unique
  username       String         @unique
  password       String?
  role           String         @default("EXTERNO")
  active         Boolean        @default(true)
  scout          Scout?         @relation(fields: [scoutId], references: [uuid])
  scoutId        String?        @unique
  familiar       Familiar?      @relation(fields: [familiarId], references: [uuid])
  familiarId     String?        @unique
  notificaciones Notificacion[]
  pushTokens     PushToken[]
}

model Scout {
  id                    Int                   @id @default(autoincrement())
  uuid                  String                @unique
  nombre                String
  apellido              String
  fechaNacimiento       DateTime
  dni                   String                @unique
  sexo                  String?
  localidad             String
  direccion             String
  codigoPostal          String?
  afiliado              Boolean               @default(true)
  telefono              String?
  nacionalidad          String?
  provincia             String?
  mail                  String?
  progresionActual      Progresion?
  religion              String?               @default("CATOLICA")
  rama                  Rama?
  equipo                Equipo?               @relation(fields: [equipoId], references: [uuid])
  equipoId              String?
  funcion               String?
  estado                String?               @default("ACTIVO")
  documentosPresentados DocumentoPresentado[]
  entregasObtenidas     EntregaRealizada[]
  familiarScout         FamiliarScout[]
  pagosRealizados       Pago[]
  eventosParticipante   EventoParticipante[]
  fechaCreacion         DateTime              @default(now())
  fechaActualizacion    DateTime              @updatedAt
  user                  User?

  @@index([equipoId])
}

model Documento {
  id                           Int                              @id @default(autoincrement())
  uuid                         String                           @unique
  nombre                       String
  vence                        Boolean
  completable                  Boolean
  fileUploadId                 String?
  requiereFamiliar             Boolean                          @default(false)
  requiereFirma                Boolean                          @default(false)
  documentoPresentado          DocumentoPresentado[]
  tipoEventoDocumentos         TipoEventoDocumento[]
  tipoEventoDocumentosParticipante TipoEventoDocumentoParticipante[]
}

model DocumentoPresentado {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique
  documento         Documento @relation(fields: [documentoId], references: [uuid])
  documentoId       String
  scout             Scout?    @relation(fields: [scoutId], references: [uuid])
  scoutId           String?
  familiar          Familiar? @relation(fields: [familiarId], references: [uuid])
  familiarId        String?
  uploadId          String?
  fechaPresentacion DateTime  @default(now())
  fechaCreacion     DateTime  @default(now())

  @@index([scoutId, documentoId])
  @@index([documentoId])
  @@index([familiarId])
}

model Pago {
  id            Int         @id @default(autoincrement())
  uuid          String      @unique
  concepto      String
  monto         Float
  rendido       Boolean     @default(false)
  metodoPago    String
  scout         Scout       @relation(fields: [scoutId], references: [uuid])
  scoutId       String
  fechaPago     DateTime
  fechaCreacion DateTime    @default(now())
  reciboPago    ReciboPago?

  @@index([scoutId])
}

model ReciboPago {
  id            Int      @id @default(autoincrement())
  uuid          String   @unique
  numeroRecibo  Int      @unique
  pago          Pago     @relation(fields: [pagoId], references: [uuid], onDelete: Cascade)
  pagoId        String   @unique
  uploadPath    String?
  fechaCreacion DateTime @default(now())
}

model Familiar {
  id                 Int             @id @default(autoincrement())
  uuid               String          @unique
  nombre             String
  apellido           String
  fechaNacimiento    DateTime
  dni                String
  sexo               String?
  localidad          String
  direccion          String
  codigoPostal       String?
  mail               String?
  telefono           String?
  nacionalidad       String?
  provincia          String?
  estadoCivil        String?
  fechaCreacion      DateTime        @default(now())
  fechaActualizacion DateTime        @updatedAt
  padreScout            FamiliarScout[]
  documentosPresentados DocumentoPresentado[]
  user                  User?
}

model FamiliarScout {
  id         Int      @id @default(autoincrement())
  familiar   Familiar @relation(fields: [familiarId], references: [uuid])
  familiarId String
  scout      Scout    @relation(fields: [scoutId], references: [uuid])
  scoutId    String
  relacion   String

  @@index([scoutId, familiarId])
  @@index([familiarId])
}

model Equipo {
  id                 Int      @id @default(autoincrement())
  uuid               String   @unique
  nombre             String   @unique
  lema               String?
  rama               String
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
  scout              Scout[]
}

model EntregaRealizada {
  id            Int      @id @default(autoincrement())
  uuid          String   @unique
  scout         Scout    @relation(fields: [scoutId], references: [uuid])
  scoutId       String
  tipoEntrega   String
  fechaEntrega  DateTime @default(now())
  fechaCreacion DateTime @default(now())

  @@index([scoutId])
}

model Aviso {
  id             Int            @id @default(autoincrement())
  uuid           String         @unique
  titulo         String
  mensaje        String
  tipo           String
  referenciaId   String?
  referenciaTipo String?
  fechaCreacion  DateTime       @default(now())
  notificaciones Notificacion[]
}

model Notificacion {
  id            Int       @id @default(autoincrement())
  uuid          String    @unique
  aviso         Aviso     @relation(fields: [avisoId], references: [uuid])
  avisoId       String
  user          User      @relation(fields: [userId], references: [uuid])
  userId        String
  leida         Boolean   @default(false)
  fechaCreacion DateTime  @default(now())
  fechaLectura  DateTime?

  @@unique([avisoId, userId])
  @@index([userId])
  @@index([avisoId])
}

model PushToken {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique
  user      User     @relation(fields: [userId], references: [uuid])
  userId    String
  platform  String
  token     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform, token])
  @@index([userId])
}

model TipoEvento {
  id                       Int                              @id @default(autoincrement())
  uuid                     String                           @unique
  nombre                   String                           @unique
  activo                   Boolean                          @default(true)
  fechaCreacion            DateTime                         @default(now())
  fechaActualizacion       DateTime                         @updatedAt
  eventos                  Evento[]
  documentosEvento         TipoEventoDocumento[]
  documentosParticipante   TipoEventoDocumentoParticipante[]
}

model TipoEventoDocumento {
  id           Int        @id @default(autoincrement())
  tipoEvento   TipoEvento @relation(fields: [tipoEventoId], references: [uuid])
  tipoEventoId String
  documento    Documento  @relation(fields: [documentoId], references: [uuid])
  documentoId  String

  @@unique([tipoEventoId, documentoId])
  @@index([tipoEventoId])
}

model TipoEventoDocumentoParticipante {
  id               Int        @id @default(autoincrement())
  tipoEvento       TipoEvento @relation(fields: [tipoEventoId], references: [uuid])
  tipoEventoId     String
  documento        Documento  @relation(fields: [documentoId], references: [uuid])
  documentoId      String
  tipoParticipante String

  @@unique([tipoEventoId, documentoId, tipoParticipante])
  @@index([tipoEventoId])
}

model Evento {
  id                 Int                  @id @default(autoincrement())
  uuid               String               @unique
  nombre             String
  descripcion        String
  tipoEvento         TipoEvento           @relation(fields: [tipoEventoId], references: [uuid])
  tipoEventoId       String
  lugarNombre        String?
  lugarDireccion     String
  lugarLocalidad     String
  lugarPartido       String
  lugarProvincia     String
  lugarLatitud       Float?
  lugarLongitud      Float?
  fechaHoraInicio    DateTime
  fechaHoraFin       DateTime
  costo              Float?
  activo             Boolean              @default(true)
  fechaCreacion      DateTime             @default(now())
  fechaActualizacion DateTime             @updatedAt
  participantes      EventoParticipante[]

  @@index([tipoEventoId])
}

model EventoParticipante {
  id               Int      @id @default(autoincrement())
  uuid             String   @unique
  evento           Evento   @relation(fields: [eventoId], references: [uuid])
  eventoId         String
  scout            Scout    @relation(fields: [scoutId], references: [uuid])
  scoutId          String
  tipoParticipante String
  fechaCreacion    DateTime @default(now())

  @@unique([eventoId, scoutId])
  @@index([eventoId])
  @@index([scoutId])
}
