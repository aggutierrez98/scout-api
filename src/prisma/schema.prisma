generator client {
  provider = "prisma-client-js"
  version = "7.0.0"
  previewFeatures = ["driverAdapters"]
  engineType      = "client" 
}

datasource db {
  provider = "sqlite"
}

enum Progresion {
  INTERRAMA
  LOBO_PATA_TIERNA
  LOBO_SALTADOR
  LOBO_RASTREADOR
  LOBO_CAZADOR
  PISTAS
  SENDA
  RUMBO
  TRAVESIA
  FUEGO
  TIERRA
  AGUA
  AIRE
  ENCUENTRO
  COMPROMISO
  PROYECCION
}

enum Rama {
  CASTORES
  MANADA
  SCOUTS
  CAMINANTES
  ROVERS
}

enum TipoObligacionPago {
  AFILIACION
  CUOTA_MENSUAL
  EVENTO
}

enum TipoPago {
  AFILIACION
  CUOTA_MENSUAL
  EVENTO
  OTRO
}

enum EstadoObligacionPago {
  PENDIENTE
  INCOMPLETO
  AL_DIA
}

model User {
  id             Int            @id @default(autoincrement())
  uuid           String         @unique
  username       String         @unique
  password       String?
  role           String         @default("EXTERNO")
  active         Boolean        @default(true)
  scout          Scout?         @relation(fields: [scoutId], references: [uuid])
  scoutId        String?        @unique
  familiar       Familiar?      @relation(fields: [familiarId], references: [uuid])
  familiarId     String?        @unique
  invitationToken String?
  notificaciones  Notificacion[]
  pushTokens      PushToken[]
  condonacionesPago CondonacionPago[]
  becasSAAC       BecaSAAC[]
}

model Scout {
  id                    Int                   @id @default(autoincrement())
  uuid                  String                @unique
  nombre                String
  apellido              String
  nombreNormalizado     String?
  apellidoNormalizado   String?
  fechaNacimiento       DateTime
  dni                   String                @unique
  sexo                  String?
  localidad             String
  direccion             String
  codigoPostal          String?
  afiliado              Boolean               @default(true)
  telefono              String?
  nacionalidad          String?
  provincia             String?
  mail                  String?
  progresionActual      Progresion?
  religion              String?               @default("CATOLICA")
  rama                  Rama?
  equipo                Equipo?               @relation(fields: [equipoId], references: [uuid])
  equipoId              String?
  funcion               String?
  estado                String?               @default("ACTIVO")
  primerCicloAfiliado   Boolean               @default(false)
  documentosPresentados DocumentoPresentado[]
  entregasObtenidas     EntregaRealizada[]
  familiarScout         FamiliarScout[]
  pagosRealizados       Pago[]
  obligacionesPago      ObligacionPago[]
  becasSAAC             BecaSAAC[]
  eventosParticipante   EventoParticipante[]
  fechaCreacion         DateTime              @default(now())
  fechaActualizacion    DateTime              @updatedAt
  user                  User?

  @@index([equipoId])
}

model Documento {
  id                           Int                              @id @default(autoincrement())
  uuid                         String                           @unique
  nombre                       String
  nombreNormalizado             String?
  requiereRenovacionAnual      Boolean                          @map("vence")
  requeridoParaIngreso         Boolean                          @default(false) @map("requeridoIngreso")
  completableDinamicamente     Boolean                          @map("completable")
  googleDriveFileId            String?                          @map("fileUploadId")
  requiereDatosFamiliar        Boolean                          @default(false) @map("requiereFamiliar")
  requiereFirmaFamiliar        Boolean                          @default(false) @map("requiereFirma")
  documentoPresentado          DocumentoPresentado[]
  tipoEventoDocumentos         TipoEventoDocumento[]
  tipoEventoDocumentosParticipante TipoEventoDocumentoParticipante[]
}

model DocumentoPresentado {
  id                Int       @id @default(autoincrement())
  uuid              String    @unique
  documento         Documento @relation(fields: [documentoId], references: [uuid])
  documentoId       String
  scout             Scout?    @relation(fields: [scoutId], references: [uuid])
  scoutId           String?
  familiar          Familiar? @relation(fields: [familiarId], references: [uuid])
  familiarId        String?
  uploadId          String?
  fechaPresentacion DateTime  @default(now())
  fechaCreacion     DateTime  @default(now())

  @@index([scoutId, documentoId])
  @@index([documentoId])
  @@index([familiarId])
}

model Pago {
  id            Int            @id @default(autoincrement())
  uuid          String         @unique
  concepto      String
  monto         Float
  rendido       Boolean        @default(false)
  metodoPago    String
  tipoPago      TipoPago       @default(OTRO)
  mesCuota      Int?
  scout         Scout          @relation(fields: [scoutId], references: [uuid])
  scoutId       String
  fechaPago     DateTime
  fechaCreacion DateTime       @default(now())
  reciboPago    ReciboPago?
  imputaciones  ImputacionPago[]
  revision      PagoRevision?

  @@index([scoutId])
  @@index([tipoPago])
}

model PagoRevision {
  id               Int       @id @default(autoincrement())
  uuid             String    @unique
  /// Pago creado (puede ser null si no se pudo identificar al scout)
  pago             Pago?     @relation(fields: [pagoId], references: [uuid], onDelete: SetNull)
  pagoId           String?   @unique
  /// PENDIENTE | RESUELTO
  estado           String    @default("PENDIENTE")
  /// Tipo de conflicto: SIN_IDENTIFICACION | SIN_SCOUTS_VINCULADOS | SCOUT_AMBIGUO | OBLIGACION_NO_CLARA
  tipoConflicto    String
  /// Detalle estructurado del conflicto: familiarId?, scoutIds?, mensaje, metodoResolucion, confianza
  conflicto        Json
  /// Raw data del comprobante tal como llegó de whatsapp-comprobantes (para re-procesar manualmente)
  datosComprobante Json
  fechaCreacion    DateTime  @default(now())
  fechaResolucion  DateTime?
  resueltoPorId    String?

  @@index([estado])
  @@index([tipoConflicto])
}

model CicloReglasPago {
  id                   Int                        @id @default(autoincrement())
  uuid                 String                     @unique
  anio                 Int                        @unique
  activo               Boolean                    @default(false)
  fechaInicio          DateTime
  fechaFin             DateTime
  /// CBUs/aliases bancarios válidos para recibir transferencias en este ciclo
  cbusAceptados        Json                       @default("[]")
  exencionPrimerCicloHabilitada Boolean @default(false)
  fechaCreacion        DateTime                   @default(now())
  fechaActualizacion   DateTime                   @updatedAt
  reglasAfiliacion     ReglaAfiliacion[]
  reglasCuotaMensual   ReglaCuotaMensual[]
  reglaDescuentoPagoAnual ReglaDescuentoPagoAnual?
  reglasDescuentoFamiliar ReglaDescuentoFamiliar[]
  obligacionesPago     ObligacionPago[]
  saldosAFavor         SaldoAFavor[]
  becasSAAC            BecaSAAC[]
}

model ReglaAfiliacion {
  id              Int             @id @default(autoincrement())
  uuid            String          @unique
  ciclo           CicloReglasPago @relation(fields: [cicloId], references: [uuid], onDelete: Cascade)
  cicloId         String
  funcionScout    String
  monto           Float
  obligatoria     Boolean         @default(true)
  fechaCreacion   DateTime        @default(now())
  fechaActualizacion DateTime     @updatedAt

  @@unique([cicloId, funcionScout])
  @@index([cicloId])
}

model ReglaCuotaMensual {
  id                Int             @id @default(autoincrement())
  uuid              String          @unique
  ciclo             CicloReglasPago @relation(fields: [cicloId], references: [uuid], onDelete: Cascade)
  cicloId           String
  mes               Int
  montoBase         Float
  cobrable          Boolean         @default(true)
  fechaCreacion     DateTime        @default(now())
  fechaActualizacion DateTime       @updatedAt

  @@unique([cicloId, mes])
  @@index([cicloId])
}

model ReglaDescuentoPagoAnual {
  id                Int             @id @default(autoincrement())
  uuid              String          @unique
  ciclo             CicloReglasPago @relation(fields: [cicloId], references: [uuid], onDelete: Cascade)
  cicloId           String          @unique
  habilitado        Boolean         @default(false)
  mesBonificado     Int?
  fechaCreacion     DateTime        @default(now())
  fechaActualizacion DateTime       @updatedAt
}

model ReglaDescuentoFamiliar {
  id                Int             @id @default(autoincrement())
  uuid              String          @unique
  ciclo             CicloReglasPago @relation(fields: [cicloId], references: [uuid], onDelete: Cascade)
  cicloId           String
  cantidadMinima    Int
  cantidadMaxima    Int?
  montoPorScout     Float
  fechaCreacion     DateTime        @default(now())
  fechaActualizacion DateTime       @updatedAt

  @@index([cicloId])
  @@unique([cicloId, cantidadMinima])
}

model ObligacionPago {
  id                Int                   @id @default(autoincrement())
  uuid              String                @unique
  ciclo             CicloReglasPago       @relation(fields: [cicloId], references: [uuid], onDelete: Cascade)
  cicloId           String
  tipo              TipoObligacionPago
  periodo           String
  scout             Scout?                @relation(fields: [scoutId], references: [uuid], onDelete: SetNull)
  scoutId           String?
  familiaClave      String
  montoEsperado     Float
  montoCondonado    Float                 @default(0)
  estado            EstadoObligacionPago  @default(PENDIENTE)
  detalleCalculo    Json?
  fechaCreacion     DateTime              @default(now())
  fechaActualizacion DateTime             @updatedAt
  imputaciones      ImputacionPago[]
  condonaciones     CondonacionPago[]

  @@index([cicloId, periodo])
  @@index([familiaClave, estado])
  @@index([scoutId, periodo])
  @@unique([cicloId, tipo, periodo, scoutId])
}

model ImputacionPago {
  id             Int           @id @default(autoincrement())
  uuid           String        @unique
  pago           Pago          @relation(fields: [pagoId], references: [uuid], onDelete: Cascade)
  pagoId         String
  obligacion     ObligacionPago @relation(fields: [obligacionId], references: [uuid], onDelete: Cascade)
  obligacionId   String
  montoImputado  Float
  fecha          DateTime      @default(now())

  @@index([pagoId])
  @@index([obligacionId])
}

model CondonacionPago {
  id                Int            @id @default(autoincrement())
  uuid              String         @unique
  obligacion        ObligacionPago @relation(fields: [obligacionId], references: [uuid], onDelete: Cascade)
  obligacionId      String
  montoCondonado    Float
  motivo            String
  condonadoPorUser  User?          @relation(fields: [condonadoPorUserId], references: [uuid], onDelete: SetNull)
  condonadoPorUserId String?
  fecha             DateTime       @default(now())

  @@index([obligacionId])
  @@index([condonadoPorUserId])
}

model SaldoAFavor {
  id                Int             @id @default(autoincrement())
  uuid              String          @unique
  familiaClave      String
  ciclo             CicloReglasPago @relation(fields: [cicloId], references: [uuid], onDelete: Cascade)
  cicloId           String
  montoDisponible   Float           @default(0)
  origen            String?
  fechaCreacion     DateTime        @default(now())
  fechaActualizacion DateTime       @updatedAt

  @@unique([familiaClave, cicloId])
  @@index([familiaClave])
  @@index([cicloId])
}

model BecaSAAC {
  id              Int             @id @default(autoincrement())
  uuid            String          @unique
  scout           Scout           @relation(fields: [scoutId], references: [uuid], onDelete: Cascade)
  scoutId         String
  ciclo           CicloReglasPago @relation(fields: [cicloId], references: [uuid], onDelete: Cascade)
  cicloId         String
  porcentaje      Float
  motivo          String?
  creadoPor       User?           @relation(fields: [creadoPorId], references: [uuid], onDelete: SetNull)
  creadoPorId     String?
  fechaCreacion   DateTime        @default(now())
  fechaActualizacion DateTime     @updatedAt

  @@unique([scoutId, cicloId])
  @@index([cicloId])
  @@index([scoutId])
}

model ReciboPago {
  id            Int      @id @default(autoincrement())
  uuid          String   @unique
  numeroRecibo  Int      @unique
  pago          Pago     @relation(fields: [pagoId], references: [uuid], onDelete: Cascade)
  pagoId        String   @unique
  uploadPath    String?
  fechaCreacion DateTime @default(now())
}

model Familiar {
  id                 Int             @id @default(autoincrement())
  uuid               String          @unique
  nombre             String
  apellido           String
  nombreNormalizado  String?
  apellidoNormalizado String?
  fechaNacimiento    DateTime
  dni                String
  sexo               String?
  localidad          String
  direccion          String
  codigoPostal       String?
  mail               String?
  telefono           String?
  nacionalidad       String?
  provincia          String?
  estadoCivil        String?
  fechaCreacion      DateTime        @default(now())
  fechaActualizacion DateTime        @updatedAt
  padreScout            FamiliarScout[]
  documentosPresentados DocumentoPresentado[]
  user                  User?
}

model FamiliarScout {
  id         Int      @id @default(autoincrement())
  familiar   Familiar @relation(fields: [familiarId], references: [uuid])
  familiarId String
  scout      Scout    @relation(fields: [scoutId], references: [uuid])
  scoutId    String
  relacion   String

  @@index([scoutId, familiarId])
  @@index([familiarId])
}

model Equipo {
  id                 Int      @id @default(autoincrement())
  uuid               String   @unique
  nombre             String   @unique
  lema               String?
  rama               String
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
  scout              Scout[]
}

model EntregaRealizada {
  id            Int      @id @default(autoincrement())
  uuid          String   @unique
  scout         Scout    @relation(fields: [scoutId], references: [uuid])
  scoutId       String
  tipoEntrega   String
  fechaEntrega  DateTime @default(now())
  fechaCreacion DateTime @default(now())

  @@index([scoutId])
}

model Aviso {
  id             Int            @id @default(autoincrement())
  uuid           String         @unique
  titulo         String
  mensaje        String
  tipo           String
  referenciaId   String?
  referenciaTipo String?
  fechaCreacion  DateTime       @default(now())
  notificaciones Notificacion[]
}

model Notificacion {
  id            Int       @id @default(autoincrement())
  uuid          String    @unique
  aviso         Aviso     @relation(fields: [avisoId], references: [uuid])
  avisoId       String
  user          User      @relation(fields: [userId], references: [uuid])
  userId        String
  leida         Boolean   @default(false)
  fechaCreacion DateTime  @default(now())
  fechaLectura  DateTime?

  @@unique([avisoId, userId])
  @@index([userId])
  @@index([avisoId])
}

model PushToken {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique
  user      User     @relation(fields: [userId], references: [uuid])
  userId    String
  platform  String
  token     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform, token])
  @@index([userId])
}

model TipoEvento {
  id                       Int                              @id @default(autoincrement())
  uuid                     String                           @unique
  nombre                   String                           @unique
  activo                   Boolean                          @default(true)
  fechaCreacion            DateTime                         @default(now())
  fechaActualizacion       DateTime                         @updatedAt
  eventos                  Evento[]
  documentosEvento         TipoEventoDocumento[]
  documentosParticipante   TipoEventoDocumentoParticipante[]
}

model TipoEventoDocumento {
  id           Int        @id @default(autoincrement())
  tipoEvento   TipoEvento @relation(fields: [tipoEventoId], references: [uuid])
  tipoEventoId String
  documento    Documento  @relation(fields: [documentoId], references: [uuid])
  documentoId  String

  @@unique([tipoEventoId, documentoId])
  @@index([tipoEventoId])
}

model TipoEventoDocumentoParticipante {
  id               Int        @id @default(autoincrement())
  tipoEvento       TipoEvento @relation(fields: [tipoEventoId], references: [uuid])
  tipoEventoId     String
  documento        Documento  @relation(fields: [documentoId], references: [uuid])
  documentoId      String
  tipoParticipante String

  @@unique([tipoEventoId, documentoId, tipoParticipante])
  @@index([tipoEventoId])
}

model Evento {
  id                 Int                  @id @default(autoincrement())
  uuid               String               @unique
  nombre             String
  nombreNormalizado  String?
  descripcion        String
  tipoEvento         TipoEvento           @relation(fields: [tipoEventoId], references: [uuid])
  tipoEventoId       String
  lugarNombre        String?
  lugarDireccion     String
  lugarLocalidad     String
  lugarPartido       String
  lugarProvincia     String
  lugarLatitud       Float?
  lugarLongitud      Float?
  centroSaludCercanoNombre    String?
  centroSaludCercanoDireccion String?
  centroSaludCercanoLocalidad String?
  comisariaCercanaNombre      String?
  comisariaCercanaDireccion   String?
  comisariaCercanaLocalidad   String?
  fechaHoraInicio    DateTime
  fechaHoraFin       DateTime
  costo              Float?
  activo             Boolean              @default(true)
  fechaCreacion      DateTime             @default(now())
  fechaActualizacion DateTime             @updatedAt
  participantes      EventoParticipante[]

  @@index([tipoEventoId])
}

model EventoParticipante {
  id               Int      @id @default(autoincrement())
  uuid             String   @unique
  evento           Evento   @relation(fields: [eventoId], references: [uuid])
  eventoId         String
  scout            Scout    @relation(fields: [scoutId], references: [uuid])
  scoutId          String
  tipoParticipante String
  fechaCreacion    DateTime @default(now())

  @@unique([eventoId, scoutId])
  @@index([eventoId])
  @@index([scoutId])
}
