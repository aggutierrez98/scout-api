  token: {{token}}
}

body:json {
  {
    "nombre": "Campamento",
    "documentosEventoIds": ["documento-uuid-aqui"],
    "documentosParticipante": [
      {
        "documentoId": "documento-uuid-aqui",
        "tipoParticipante": "JOVEN_PROTAGONISTA"
      }
    ]
  }
}
