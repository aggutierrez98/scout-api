meta {
  name: Comprobante (WhatsApp)
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/webhook/comprobante
  body: json
  auth: none
}

headers {
  X-Webhook-Source: whatsapp-comprobantes
  X-Webhook-Secret: {{webhook_secret}}
}

body:json {
  {
    "evento": "comprobante_recibido",
