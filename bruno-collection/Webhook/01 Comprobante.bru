    "datos": {
      "es_comprobante": true,
      "monto": 45000,
      "fecha": "11/04/2026",
      "hora": "10:30",
      "cbu_alias_destino": "alias.destino",
      "banco_emisor": "Banco Galicia",
      "cuit_emisor": null,
      "nombre_emisor": "Juan Pérez",
