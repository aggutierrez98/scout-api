meta {
  name: Get Pagos
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/pago
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

params:query {
  ~limit: 15
  ~offset: 0
  ~scoutId: scout-uuid-aqui
  ~metodoPago: TRANSFERENCIA
  ~rendido: false
  ~tiempoDesde: 2026-01-01T00:00:00.000Z
  ~tiempoHasta: 2026-12-31T23:59:59.000Z
  ~ramas: SCOUTS
  ~equipos: equipo-uuid-aqui
}
