meta {
  name: Import Pagos CSV
  type: http
  seq: 4
}

post {
  url: {{base_url}}/api/pago/import
  body: multipartForm
  auth: bearer
}

headers {
  ~Authorization: Bearer {{token}}
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  csv: @file(/Users/aggutierrez/Downloads/Pagos de todo el grupo 2026 - Hoja 8.csv)
}
