meta {
  name: Get Documentos
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/documento
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

params:query {
  ~limit: 15
  ~offset: 0
  ~requiereRenovacionAnual: true
  ~tiempoDesde: 2026-01-01T00:00:00.000Z
  ~tiempoHasta: 2026-12-31T23:59:59.000Z
}
